# =============================================================================
# .gitignore — Atlas Social de Hortolândia (versão segura)
# =============================================================================

# -----------------------------------------------------------------------------
# BANCOS DE DADOS (QUALQUER LOCAL)
# -----------------------------------------------------------------------------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# DADOS SENSÍVEIS (MICRODADOS)
# -----------------------------------------------------------------------------
*.csv
*.xlsx
*.xls
*.parquet
*.feather
*.json
*.dbf
*.txt

# -----------------------------------------------------------------------------
# DIRETÓRIOS SENSÍVEIS (RECOMENDADO)
# -----------------------------------------------------------------------------
dados_brutos/
dados_sensiveis/
dados_privados/
outputs_privados/
tmp/
temp/
cecad/

# -----------------------------------------------------------------------------
# ARQUIVOS TEMPORÁRIOS DE SISTEMA
# -----------------------------------------------------------------------------
Thumbs.db
desktop.ini
.DS_Store

# -----------------------------------------------------------------------------
# ARQUIVOS TEMPORÁRIOS DE EDITORES
# -----------------------------------------------------------------------------
*.tmp
*.bak
*~

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.env
